# Which LLM provider to use: "openai", "anthropic", or "mock"
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-5.5
OPENAI_EMBED_MODEL=text-embedding-3-small

# Anthropic (used when LLM_PROVIDER=anthropic; embeddings still use OpenAI or local fallback)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_CHAT_MODEL=claude-3-5-sonnet-latest

# App
DATABASE_URL=sqlite:///./applyengine.db
CORS_ORIGINS=http://localhost:3000

# Auth
# Long random secret used to sign JWTs. Generate with: python -c "import secrets;print(secrets.token_urlsafe(48))"
JWT_SECRET=dev-insecure-change-me
# If set, new registrations must supply this code (protects your public deployment + API bill).
SIGNUP_CODE=
